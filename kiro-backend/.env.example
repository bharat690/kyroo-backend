# Copy this file to .env and fill in real values.
# Required for the AI chat brain to respond:
ANTHROPIC_API_KEY=

# Required for any database-backed route (signup, chat history, tracking, etc.):
SUPABASE_URL=
SUPABASE_KEY=

# Optional — payments (Razorpay test/live keys):
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional — WhatsApp delivery via Meta Cloud API (leave blank to run in "pending_setup" mode):
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=kyroo_verify_2026

# Optional — semantic memory (leave blank to skip memory search/save silently):
VOYAGE_API_KEY=
